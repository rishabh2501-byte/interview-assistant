# ──────────────────────────────────────────────────────────────
# Interview Assistant — Backend env
# Copy to `.env` and fill in real values. Anything marked REQUIRED
# will make the server refuse to start if missing.
# ──────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL (REQUIRED: DB_NAME, DB_USER)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=interview_platform
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT (REQUIRED)
# Use a long random string in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Razorpay — leave blank to disable paid plans in dev
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# OpenAI (REQUIRED for AI features)
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXX
# Optional overrides — leave commented to use defaults.
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Frontend URL — used for QR/pairing links + CORS.
# Dev (phone on same WiFi): set to http://<YOUR_MAC_LAN_IP>:5173
# Prod: your deployed frontend origin, e.g. https://app.yourdomain.com
FRONTEND_URL=http://localhost:5173

# Public URL of THIS backend — used in emails / absolute links.
# Prod example: https://api.yourdomain.com
# PUBLIC_BACKEND_URL=http://localhost:5000

# Extra CORS origins (comma-separated). Useful for prod domains that
# aren't localhost / LAN IPs, which are allowed automatically.
# EXTRA_CORS_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com

# ─── Business / pricing knobs ──────────────────────────────────
# Raw cost per session in INR (used to compute margin reporting).
COST_PER_SESSION_INR=20
# Top-up validity add-on (days) when applied to an existing subscription.
TOPUP_EXTENSION_DAYS=180

# ─── SMTP (transactional email: verify + password reset) ───────
# Leave ALL blank for dev: reset/verify links are logged to the server
# console instead of sent.
#
# Option A — Gmail (simplest for dev):
# SMTP_SERVICE=gmail
# SMTP_USER=youremail@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx     # 16-char App Password, NOT your login pwd
#
# Option B — Generic SMTP (SendGrid, Mailgun, Resend, etc.):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false                 # true only for port 465
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxxxx
#
# Optional:
# SMTP_FROM=no-reply@yourdomain.com
# APP_NAME=Interview Assistant
