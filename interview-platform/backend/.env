# Server
PORT=5000
NODE_ENV=development

# PostgreSQL — update these to match your local setup
DB_HOST=localhost
DB_PORT=5432
DB_NAME=interview_platform
DB_USER=rishabh.rai
DB_PASSWORD=

# JWT
JWT_SECRET=interview_platform_super_secret_jwt_key_2024
JWT_EXPIRES_IN=7d

# Razorpay — get test keys from https://dashboard.razorpay.com
# Leave as placeholder to start the server; payment routes will error until filled
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=placeholder_secret

# OpenAI — get key from https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Frontend URL — used to build the QR / mobile pairing URL.
# Set this to your Mac's LAN IP so your phone can reach it on the same WiFi.
# Find it with: `ipconfig getifaddr en0`
FRONTEND_URL=http://192.168.29.176:5173
