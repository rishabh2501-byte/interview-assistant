# ──────────────────────────────────────────────────────────────
# Interview Assistant — Frontend (Vite) env
# Copy to `.env` (gitignored) and fill in real values.
# Only vars prefixed with VITE_ are exposed to client code.
# ──────────────────────────────────────────────────────────────

# Backend API base URL.
#   Dev:  leave commented — Vite proxies /api to localhost:5000.
#   Prod: set to your deployed backend, e.g. https://api.yourdomain.com
# VITE_API_BASE_URL=https://api.yourdomain.com

# WebSocket URL for dual-device relay.
#   Dev:  leave commented — Mobile.jsx derives it from window.location.
#   Prod: set to wss://api.yourdomain.com/ws
# VITE_BACKEND_WS=wss://api.yourdomain.com/ws
